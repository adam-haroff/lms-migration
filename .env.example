# Canvas sandbox credentials for lms-canvas-preview
# Copy this file to .env and fill in your real values.
# .env is listed in .gitignore and will never be committed.
# .env.example is a placeholder template only — never put real values here.

# Canvas base URL (just the domain — no /courses/... path)
CANVAS_SANDBOX_URL=https://yourschool.instructure.com

# Personal access token with course content-migration scope
# Canvas > Account > Settings > Approved Integrations > + New Access Token
CANVAS_SANDBOX_TOKEN=your-token-here

# The ID of your existing sandbox course.
# Find it in the Canvas URL when viewing the course: /courses/12345 → 12345
# This ID changes when your sandbox is reset — update .env when it does.
CANVAS_SANDBOX_COURSE_ID=12345
